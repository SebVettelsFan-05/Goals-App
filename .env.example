# ---- Client (build-time, public) ----
# The public VAPID key. Safe to expose. Already set in .env.
VITE_VAPID_PUBLIC_KEY=

# ---- Server (Vercel env vars — set in Project Settings, NOT committed) ----
# VAPID keypair. Generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Shared secret protecting /api/tick. Vercel Cron sends it automatically;
# external cron services pass it as ?key=THISVALUE
CRON_SECRET=

# KV store (Vercel KV or Upstash Redis). Either pair works:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
